# ============================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# ============================================

# ============ DATABASE ============
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mixmind

# ============ STRIPE ============
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_ACCOUNT_ID=acct_YOUR_STRIPE_ACCOUNT_ID

# ============ EMAIL (GMAIL) ============
# You MUST set these for coupon emails to work!
# Get app password from: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=your-app-specific-password

# Alternative: SendGrid
# Uncomment to use SendGrid instead of Gmail
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=SG.your_sendgrid_api_key

# ============ FRONTEND ============
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ============ STRIPE STATUS ============
# Set to "true" to enable demo mode where stripe is mocked
DEMO_MODE=false

# ============ DJ MODE ============
# Stripe account ID for DJ mode (if using DJ features)
DJ_STRIPE_ACCOUNT_ID=acct_YOUR_DJ_ACCOUNT_ID

# ============ NODE ENVIRONMENT ============
NODE_ENV=development
PORT=4000
